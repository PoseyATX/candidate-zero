{
  "name": "candidate-zero",
  "version": "0.0.1",
  "description": "CANDIDATE ZERO — A Hot Texas Primary (modular TypeScript baseline for eventual Swift/iOS)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "harness:resolve": "npx tsx src/harness/test-resolve.ts",
    "harness:smoke": "npx tsx src/harness/smoke-play.ts",
    "harness:ballot": "npx tsx src/harness/ballot-qualification.ts",
    "harness:loop": "npx tsx src/harness/play-loop-demo.ts",
    "harness:strategies": "npx tsx src/harness/multi-strategy.ts",
    "harness:ac1": "npx tsx src/harness/ac1-determinism.ts",
    "harness:ac1-parity": "npx tsx src/harness/ac1-prototype-parity.ts",
    "harness:audit": "npx tsx src/harness/audit-srd-plays.ts",
    "harness:calendar": "npx tsx src/harness/primary-general.ts",
    "harness:setup": "npx tsx src/harness/setup-bind.ts",
    "play": "npx tsx src/cli/play.ts",
    "play:auto": "npx tsx src/cli/play.ts --auto labor --weeks 8",
    "play:full": "npx tsx src/cli/play.ts --auto labor --full",
    "harness:yields": "npx tsx src/harness/yield-tables.ts",
    "harness:full": "npx tsx src/harness/full-campaign.ts",
    "harness:dopamine": "npx tsx src/harness/dopamine.ts",
    "harness:grounds": "npx tsx src/harness/grounds.ts",
    "harness:dead-refs": "npx tsx src/harness/dead-refs.ts",
    "harness:shop": "npx tsx src/harness/shop.ts",
    "harness:obligations": "npx tsx src/harness/obligations.ts",
    "harness:debt": "npx tsx src/harness/debt.ts",
    "harness:session": "npx tsx src/harness/session.ts",
    "harness:starmap": "npx tsx src/harness/starmap.ts",
    "harness:matrix": "npx tsx src/harness/matrix.ts",
    "harness:outside": "npx tsx src/harness/outside.ts",
    "harness:chronicle": "npx tsx src/harness/chronicle-waiting.ts",
    "harness:waiting": "npx tsx src/harness/waiting.ts",
    "harness": "npm run harness:resolve && npm run harness:smoke && npm run harness:ballot && npm run harness:strategies && npm run harness:ac1 && npm run harness:ac1-parity && npm run harness:audit && npm run harness:calendar && npm run harness:setup && npm run harness:yields && npm run harness:full && npm run harness:dopamine && npm run harness:grounds && npm run harness:dead-refs && npm run harness:shop && npm run harness:obligations && npm run harness:debt && npm run harness:session && npm run harness:starmap && npm run harness:matrix && npm run harness:outside && npm run harness:chronicle && npm run harness:waiting"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^8.1.5"
  }
}
